POSTGRES_DB=wsai
POSTGRES_USER=wsai
POSTGRES_PASSWORD=replace_with_a_strong_db_password

# At least 32 characters. Generate one with:
# openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_jwt_secret
CORS_ALLOW_ORIGINS=https://wsai.tw,https://www.wsai.tw,http://localhost:3010,http://127.0.0.1:3010
MAIL_FROM=no-reply@wsai.tw
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
VERIFY_LINK_BASE=https://wsai.tw/verify-email

# Optional API keys
COINGECKO_DEMO_API_KEY=
CMC_API_KEY=
